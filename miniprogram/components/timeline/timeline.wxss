.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline__node {
  display: flex;
  gap: 16px;
}

.timeline__node--gwb {
  margin-top: 8px;
}

.timeline__node--end {
  margin-top: 2px;
}

.timeline__rail {
  width: 14px;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline__dot {
  width: 14px;
  height: 14px;
  border-radius: 50%;
}

.timeline__dot--start {
  background: #33B338;
}

.timeline__dot--gwb {
  background: #F59E0A;
}

.timeline__dot--end {
  background: #1D4F91;
}

.timeline__line {
  width: 2px;
  flex: 1;
  min-height: 58px;
  background: #D7DDE6;
}

.timeline__content {
  display: flex;
  flex-direction: column;
  gap: 4px;
  padding-bottom: 16px;
}

.timeline__content--gwb {
  gap: 6px;
}

.timeline__content--end {
  padding-bottom: 0;
}

.timeline__heading-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.timeline__time {
  color: #1A1A2E;
  font-size: 16px;
  font-weight: 700;
  line-height: 1.2;
}

.timeline__tag {
  padding: 3px 8px;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 500;
  line-height: 1;
}

.timeline__tag--start {
  background: #EDF7ED;
  color: #21A645;
}

.timeline__tag--end {
  background: #E0EDF7;
  color: #1D4F91;
}

.timeline__place {
  color: #6B7380;
  font-size: 13px;
  line-height: 1.4;
}

.timeline__bridge-title {
  color: #1A1A2E;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.25;
}

.timeline__toll-card {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  padding: 8px 12px;
  margin-top: 1px;
  border-radius: 10px;
  background: #FFF7E5;
  border: 1px solid rgba(245, 158, 10, 0.3);
}

.timeline__toll-icon {
  font-size: 16px;
  line-height: 1;
}

.timeline__toll-main {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.timeline__toll-caption {
  color: #8C8059;
  font-size: 11px;
  line-height: 1.3;
}

.timeline__toll-price-row {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-wrap: wrap;
}

.timeline__toll-amount {
  color: #D98005;
  font-size: 18px;
  font-weight: 700;
  line-height: 1.2;
}

.timeline__toll-arrow {
  color: #8C8059;
  font-size: 12px;
  font-weight: 500;
}

.timeline__toll-passenger {
  color: #21A645;
  font-size: 18px;
  font-weight: 700;
  line-height: 1.2;
}