.trip-detail-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F5F7FA;
}

.trip-detail-page__header {
  height: 56px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
}

.trip-detail-page__header-icon {
  color: #262633;
  font-size: 22px;
  font-weight: 500;
}

.trip-detail-page__header-title {
  color: #1A1A2E;
  font-size: 17px;
  font-weight: 700;
}

.trip-detail-page__header-menu {
  color: #8C94A1;
  font-size: 18px;
  font-weight: 500;
}

.trip-detail-page__driver-card {
  height: 80px;
  padding: 16px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
  background: #FFFFFF;
}

.trip-detail-page__avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid #9EB3D9;
  flex-shrink: 0;
}

.trip-detail-page__driver-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.trip-detail-page__driver-name-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.trip-detail-page__driver-name {
  color: #1A1A2E;
  font-size: 17px;
  font-weight: 700;
}

.trip-detail-page__driver-badge {
  padding: 3px 6px;
  border-radius: 4px;
  background: #E0EDF7;
  color: #1D4F91;
  font-size: 10px;
  font-weight: 600;
  line-height: 1;
}

.trip-detail-page__driver-stats {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.trip-detail-page__driver-stat {
  color: #8C94A1;
  font-size: 13px;
  line-height: 1.2;
}

.trip-detail-page__divider {
  width: 100%;
  height: 8px;
  background: #F5F7FA;
}

.trip-detail-page__section {
  padding: 20px;
  background: #FFFFFF;
}

.trip-detail-page__section--route {
  padding-bottom: 18px;
}

.trip-detail-page__section--fees,
.trip-detail-page__section--passengers {
  padding-top: 16px;
  padding-bottom: 16px;
}

.trip-detail-page__section-title {
  color: #1A1A2E;
  font-size: 16px;
  font-weight: 700;
  line-height: 1.2;
}

.trip-detail-page__section-gap {
  height: 16px;
}

.trip-detail-page__fee-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 12px;
}

.trip-detail-page__fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.trip-detail-page__fee-label-wrap {
  display: flex;
  align-items: center;
  gap: 4px;
}

.trip-detail-page__fee-label {
  color: #6B7380;
  font-size: 14px;
}

.trip-detail-page__fee-note {
  color: #B2B8BF;
  font-size: 11px;
}

.trip-detail-page__fee-value {
  color: #1A1A2E;
  font-size: 15px;
  font-weight: 600;
}

.trip-detail-page__fee-subtle {
  color: #99A1A8;
  font-size: 14px;
}

.trip-detail-page__fee-included {
  color: #33A659;
  font-size: 12px;
  font-weight: 600;
}

.trip-detail-page__fee-divider {
  width: 100%;
  height: 1px;
  background: #EBEDF2;
}

.trip-detail-page__fee-row--total {
  align-items: flex-end;
}

.trip-detail-page__total-label {
  color: #1A1A2E;
  font-size: 16px;
  font-weight: 700;
}

.trip-detail-page__total-wrap {
  display: flex;
  align-items: flex-end;
  gap: 0;
}

.trip-detail-page__total-value {
  color: #1D4F91;
  font-size: 22px;
  font-weight: 700;
  line-height: 1;
}

.trip-detail-page__total-unit {
  color: #8C94A1;
  font-size: 14px;
  line-height: 1.1;
}

.trip-detail-page__section-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.trip-detail-page__passenger-count {
  color: #8C94A1;
  font-size: 13px;
}

.trip-detail-page__passenger-list {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-top: 12px;
}

.trip-detail-page__passenger-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.trip-detail-page__passenger-avatar,
.trip-detail-page__passenger-empty {
  width: 40px;
  height: 40px;
  border-radius: 50%;
}

.trip-detail-page__passenger-empty {
  border: 2px dashed #D8DEE8;
  background: #FFFFFF;
}

.trip-detail-page__passenger-name {
  color: #6B7380;
  font-size: 11px;
}

.trip-detail-page__passenger-empty-label {
  color: #BFC4CC;
  font-size: 11px;
}

.trip-detail-page__cta-wrap {
  padding: 12px 20px calc(env(safe-area-inset-bottom) + 16px);
  background: #FFFFFF;
}

.trip-detail-page__cta {
  width: 100%;
  height: 50px;
  border-radius: 16px;
  background: #1D4F91;
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 700;
  line-height: 50px;
}